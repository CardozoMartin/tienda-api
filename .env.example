# Base de datos
DATABASE_URL="mysql://usuario:contraseña@localhost:3306/tienda_db"

# JWT
JWT_SECRET="tu_secreto_super_seguro_cambiame"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="tu_refresh_secreto_cambiame"
JWT_REFRESH_EXPIRES_IN="30d"

# Servidor
PORT=3000
NODE_ENV="development"
API_PREFIX="/api/v1"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Uploads
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880

# Configuración de correo electrónico
SMTP_HOST="provedor_smtp"
SMTP_PORT="puerto"
SMTP_USER="email@example.com"
SMTP_PASS="tucontraseñasegura"

# URL del frontend para redirecciones
FRONTEND_URL="http://localhost:5173"


