// ─────────────────────────────────────────────
// EMAIL MARKETING — Campañas masivas
// El dueño arma una campaña y la envía a un segmento de sus contactos.
// El envío se procesa en background (worker) creando un CampanaEnvio por
// destinatario, respetando un rate-limit del proveedor propio del dueño.
// ─────────────────────────────────────────────

enum SegmentoCampana {
  CLIENTES_REGISTRADOS // todos los ClienteTienda verificados y activos
  COMPRADORES // emails que hicieron al menos un pedido
  AMBOS // registrados + compradores (deduplicado)
}

enum EstadoCampana {
  BORRADOR // creada, todavía no se mandó
  ENCOLADA // lista para procesar por el worker
  ENVIANDO // el worker está procesando sus envíos
  ENVIADA // todos los envíos procesados
  FALLIDA // no se pudo (ej. config de email inválida)
}

enum EstadoEnvio {
  PENDIENTE
  ENVIADO
  FALLIDO
}

model Campana {
  id                 Int             @id @default(autoincrement())
  tiendaId           Int
  asunto             String          @db.VarChar(200)
  // Cuerpo en HTML (lo arma el compositor del front). Puede incluir la imagen.
  cuerpoHtml         String          @db.Text
  imagenUrl          String?         @db.VarChar(500)
  segmento           SegmentoCampana
  estado             EstadoCampana   @default(BORRADOR)
  totalDestinatarios Int             @default(0)
  enviados           Int             @default(0)
  fallidos           Int             @default(0)
  creadoEn           DateTime        @default(now())
  actualizadoEn      DateTime        @updatedAt
  encoladaEn         DateTime?
  finalizadaEn       DateTime?
  tienda             Tienda          @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  envios             CampanaEnvio[]

  @@index([tiendaId])
  @@index([estado])
  @@map("campanas")
}

model CampanaEnvio {
  id        Int         @id @default(autoincrement())
  campanaId Int
  email     String      @db.VarChar(180)
  nombre    String?     @db.VarChar(150)
  estado    EstadoEnvio @default(PENDIENTE)
  error     String?     @db.VarChar(500)
  intentos  Int         @default(0)
  enviadoEn DateTime?
  creadoEn  DateTime    @default(now())
  campana   Campana     @relation(fields: [campanaId], references: [id], onDelete: Cascade)

  @@index([campanaId, estado])
  @@map("campana_envios")
}
