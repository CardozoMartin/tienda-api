generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum RolUsuario {
  ADMIN
  OWNER
  CLIENT
}









// ─────────────────────────────────────────────
// USUARIO
// ─────────────────────────────────────────────

model Usuario {
  id                    Int      @id @default(autoincrement())
  nombre                String   @db.VarChar(100)
  apellido              String   @db.VarChar(100)
  email                 String   @unique @db.VarChar(180)
  passwordHash          String   @db.VarChar(255)
  rol                   RolUsuario @default(CLIENT)
  telefono              String?  @db.VarChar(30)
  avatarUrl             String?  @db.VarChar(500)
  emailVerificado       Boolean  @default(false)
  tokenVerificacion     String?  @db.VarChar(100)
  tokenVencVerificacion DateTime?
  tokenResetPass        String?  @db.VarChar(100)
  tokenVencReset        DateTime?
  activo                Boolean  @default(false)
  creadoEn              DateTime @default(now())
  actualizadoEn         DateTime @updatedAt

  tienda              Tienda?
  resenasProducto     ResenaProducto[]
  resenasTienda       ResenaTienda[]
  logBusquedas        LogBusqueda[]

  @@map("usuarios")
}

// ─────────────────────────────────────────────
// PLANTILLA
// ─────────────────────────────────────────────

model PlantillaTienda {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(80)
  descripcion   String?  @db.Text
  previewUrl    String?  @db.VarChar(500)
  defaultConfig Json?
  sortOrder     Int      @default(0)
  activo        Boolean  @default(true)

  tiendas       Tienda[]

  @@map("plantillas_tienda")
}

// ─────────────────────────────────────────────
// TIENDA
// ─────────────────────────────────────────────

model Tienda {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @unique
  plantillaId   Int?
  slug          String   @unique @db.VarChar(120)
  nombre        String   @db.VarChar(150)
  titulo        String?  @db.VarChar(200)
  descripcion   String?  @db.Text
  logoUrl       String?  @db.VarChar(500)
  bannerUrl     String?  @db.VarChar(500)
  whatsapp      String?  @db.VarChar(30)
  instagram     String?  @db.VarChar(100)
  facebook      String?  @db.VarChar(100)
  sitioWeb      String?  @db.VarChar(255)
  pais          String?  @db.VarChar(80)
  provincia     String?  @db.VarChar(80)
  ciudad        String?  @db.VarChar(80)
  activa        Boolean  @default(true)
  publica       Boolean  @default(true)
  vistas        Int      @default(0)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario        Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  plantilla      PlantillaTienda?  @relation(fields: [plantillaId], references: [id])
  temaConfig     TiendaTemaConfig?
  metodosPago    MetodoPagoTienda[]
  metodosEntrega MetodoEntregaTienda[]
  productos      Producto[]
  carrusel       CarruselImagen[]
  resenas        ResenaTienda[]
  clientes     ClienteTienda[]
  carritos  Carrito[]
pedidos   Pedido[]

  @@index([usuarioId])
  @@index([plantillaId])
  @@map("tiendas")
}

// ─────────────────────────────────────────────
// TEMA CONFIG
// ─────────────────────────────────────────────

enum NavbarStyle {
  STICKY
  TRANSPARENT
  FLOATING
}

model TiendaTemaConfig {
  tiendaId          Int         @id
  colorAcento       String?     @db.Char(7)
  modoOscuro        Boolean     @default(true)
  navbarStyle       NavbarStyle @default(TRANSPARENT)
  heroTitulo        String?     @db.VarChar(200)
  heroSubtitulo     String?     @db.VarChar(300)
  heroCtaTexto      String?     @db.VarChar(100)
  cardMostrarPrecio Boolean     @default(true)
  cardMostrarBadge  Boolean     @default(true)
  seccionesVisibles Json?
  creadoEn          DateTime    @default(now())
  actualizadoEn     DateTime    @updatedAt

  tienda Tienda @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@map("tienda_tema_config")
}

// ─────────────────────────────────────────────
// CATÁLOGO MÉTODOS DE PAGO
// ─────────────────────────────────────────────

model MetodoPago {
  id          Int                @id @default(autoincrement())
  nombre      String             @unique @db.VarChar(80)
  icono       String?            @db.VarChar(50)
  descripcion String?            @db.VarChar(255)
  activo      Boolean            @default(true)
  orden       Int                @default(0)

  tiendas     MetodoPagoTienda[]
  pedidos  Pedido[]

  @@map("metodos_pago")
}

// ─────────────────────────────────────────────
// CATÁLOGO MÉTODOS DE ENTREGA
// ─────────────────────────────────────────────

model MetodoEntrega {
  id           Int                   @id @default(autoincrement())
  nombre       String                @unique @db.VarChar(80)
  icono        String?               @db.VarChar(50)
  descripcion  String?               @db.VarChar(255)
  permiteZona  Boolean               @default(false)
  activo       Boolean               @default(true)
  orden        Int                   @default(0)

  tiendas      MetodoEntregaTienda[]
  pedidos  Pedido[]

  @@map("metodos_entrega")
}

// ─────────────────────────────────────────────
// RELACIÓN TIENDA - MÉTODO DE PAGO
// ─────────────────────────────────────────────

model MetodoPagoTienda {
  tiendaId     Int
  metodoPagoId Int
  detalle      String?    @db.VarChar(255)

  tienda       Tienda     @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  metodoPago   MetodoPago @relation(fields: [metodoPagoId], references: [id], onDelete: Restrict)

  @@id([tiendaId, metodoPagoId])
  @@index([metodoPagoId])
  @@map("metodos_pago_tienda")
}

// ─────────────────────────────────────────────
// RELACIÓN TIENDA - MÉTODO DE ENTREGA
// ─────────────────────────────────────────────

model MetodoEntregaTienda {
  tiendaId        Int
  metodoEntregaId Int
  zonaCobertura   String?       @db.VarChar(255)
  detalle         String?       @db.VarChar(255)

  tienda          Tienda        @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  metodoEntrega   MetodoEntrega @relation(fields: [metodoEntregaId], references: [id], onDelete: Restrict)

  @@id([tiendaId, metodoEntregaId])
  @@index([metodoEntregaId])
  @@map("metodos_entrega_tienda")
}

// ─────────────────────────────────────────────
// CARRUSEL / GALERÍA DE LA TIENDA
// ─────────────────────────────────────────────

model CarruselImagen {
  id        Int      @id @default(autoincrement())
  tiendaId  Int
  url       String   @db.VarChar(500)
  titulo    String?  @db.VarChar(200)
  subtitulo String?  @db.VarChar(300)
  linkUrl   String?  @db.VarChar(500)
  orden     Int      @default(0)
  activa    Boolean  @default(true)

  tienda    Tienda   @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@index([tiendaId])
  @@map("carrusel_imagenes")
}

// ─────────────────────────────────────────────
// CATEGORÍAS
// ─────────────────────────────────────────────

model Categoria {
  id        Int         @id @default(autoincrement())
  padreId   Int?
  nombre    String      @db.VarChar(100)
  slug      String      @unique @db.VarChar(120)
  iconoUrl  String?     @db.VarChar(500)
  activa    Boolean     @default(true)

  padre     Categoria?  @relation("CategoriaHijos", fields: [padreId], references: [id])
  hijos     Categoria[] @relation("CategoriaHijos")
  productos Producto[]

  @@index([padreId])
  @@map("categorias")
}

// ─────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────

model Tag {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique @db.VarChar(80)
  productos Producto[]

  @@map("tags")
}

// ─────────────────────────────────────────────
// PRODUCTO
// ─────────────────────────────────────────────

model Producto {
  id                 Int      @id @default(autoincrement())
  tiendaId           Int
  categoriaId        Int?
  nombre             String   @db.VarChar(200)
  descripcion        String?  @db.Text
  precio             Decimal  @db.Decimal(12, 2)
  precioOferta       Decimal? @db.Decimal(12, 2)
  moneda             String   @default("ARS") @db.Char(3)
  imagenPrincipalUrl String?  @db.VarChar(500)
  disponible         Boolean  @default(true)
  destacado          Boolean  @default(false)
  vistas             Int      @default(0)
  creadoEn           DateTime @default(now())
  actualizadoEn      DateTime @updatedAt

  tienda    Tienda     @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  imagenes  ProductoImagen[]
  variantes ProductoVariante[]
  tags      Tag[]
  resenas   ResenaProducto[]
  carritoItems  CarritoItem[]
pedidoItems   PedidoItem[]

  @@index([tiendaId])
  @@index([categoriaId])
  @@map("productos")
}

// ─────────────────────────────────────────────
// IMÁGENES DEL PRODUCTO
// ─────────────────────────────────────────────

model ProductoImagen {
  id         Int      @id @default(autoincrement())
  productoId Int
  url        String   @db.VarChar(500)
  orden      Int      @default(0)

  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@map("producto_imagenes")
}

// ─────────────────────────────────────────────
// VARIANTES DEL PRODUCTO
// ─────────────────────────────────────────────

model ProductoVariante {
  id          Int      @id @default(autoincrement())
  productoId  Int
  nombre      String   @db.VarChar(150)
  sku         String?  @db.VarChar(100)
  precioExtra Decimal  @default(0.00) @db.Decimal(10, 2)
  imagenUrl   String?  @db.VarChar(500)
  disponible  Boolean  @default(true)

  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
carritoItems  CarritoItem[]
pedidoItems   PedidoItem[]
  @@index([productoId])
  @@map("producto_variantes")
}

// ─────────────────────────────────────────────
// RESEÑAS DE TIENDA
// ─────────────────────────────────────────────

model ResenaTienda {
  id           Int       @id @default(autoincrement())
  tiendaId     Int
  usuarioId    Int?
  autorNombre  String?   @db.VarChar(100)
  calificacion Int
  comentario   String?   @db.Text
  aprobada     Boolean   @default(false)
  eliminada    Boolean   @default(false)
  respuesta    String?   @db.Text
  respuestaEn  DateTime?
  creadoEn     DateTime  @default(now())

  tienda       Tienda    @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  usuario      Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([tiendaId])
  @@index([usuarioId])
  @@map("resenas_tienda")
}

// ─────────────────────────────────────────────
// RESEÑAS DE PRODUCTO
// ─────────────────────────────────────────────

model ResenaProducto {
  id           Int       @id @default(autoincrement())
  productoId   Int
  usuarioId    Int?
  autorNombre  String?   @db.VarChar(100)
  calificacion Int
  comentario   String?   @db.Text
  aprobada     Boolean   @default(false)
  eliminada    Boolean   @default(false)
  respuesta    String?   @db.Text
  respuestaEn  DateTime?
  creadoEn     DateTime  @default(now())

  producto     Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario      Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([usuarioId])
  @@map("resenas_producto")
}

// ─────────────────────────────────────────────
// LOG DE BÚSQUEDAS
// ─────────────────────────────────────────────

model LogBusqueda {
  id         BigInt   @id @default(autoincrement())
  termino    String   @db.VarChar(255)
  tiendaId   Int?
  usuarioId  Int?
  resultados Int?     @default(0)
  creadoEn   DateTime @default(now())

  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([tiendaId])
  @@map("log_busquedas")
}

// ─────────────────────────────────────────────
// CLIENTE POR TIENDA
// ─────────────────────────────────────────────

model ClienteTienda {
  id               Int       @id @default(autoincrement())
  tiendaId         Int
  email            String    @db.VarChar(180)
  nombre           String    @db.VarChar(100)
  apellido         String    @db.VarChar(100)
  telefono         String    @db.VarChar(30)
  passwordHash     String    @db.VarChar(255)
  emailVerificado  Boolean   @default(false)
  tokenVerif       String?   @db.VarChar(100)
  tokenVerifVenc   DateTime?
  activo           Boolean   @default(true)
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt

  tienda           Tienda           @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  direcciones      DireccionCliente[]
  carritos  Carrito[]
pedidos   Pedido[]
  // pedidos          Pedido[]         // lo usás cuando implementes pedidos

  // La clave: mismo email puede existir en distintas tiendas
  @@unique([tiendaId, email])
  @@index([tiendaId])
  @@map("clientes_tienda")
}

// ─────────────────────────────────────────────
// DIRECCIÓN DEL CLIENTE
// ─────────────────────────────────────────────
// Separada porque un cliente puede tener varias
// (casa, trabajo, etc.) y también la usás en el pedido

model DireccionCliente {
  id           Int           @id @default(autoincrement())
  clienteId    Int
  alias        String?       @db.VarChar(50)   // "Casa", "Trabajo"
  calle        String        @db.VarChar(150)
  numero       String?       @db.VarChar(20)
  piso         String?       @db.VarChar(20)
  ciudad       String        @db.VarChar(80)
  provincia    String        @db.VarChar(80)
  codigoPostal String?       @db.VarChar(20)
  indicaciones String?       @db.VarChar(300)  // "timbre roto, llamar por cel"
  esPrincipal  Boolean       @default(false)
  creadoEn     DateTime      @default(now())

  cliente      ClienteTienda @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("direcciones_cliente")
}


// ─────────────────────────────────────────────
// CARRITO
// ─────────────────────────────────────────────
// El carrito persiste en DB. Si el cliente está
// logueado se asocia a clienteId, si es invitado
// se identifica por sessionId (UUID generado en frontend)

model Carrito {
  id          Int      @id @default(autoincrement())
  tiendaId    Int
  clienteId   Int?     // null = invitado
  sessionId   String   @db.VarChar(100) // UUID del browser, siempre presente
  expiresAt   DateTime // se limpia con un cron si no se convierte en pedido
  creadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  tienda      Tienda         @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  cliente     ClienteTienda? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  items       CarritoItem[]

  // Un sessionId solo tiene un carrito activo por tienda
  @@unique([tiendaId, sessionId])
  @@index([clienteId])
  @@map("carritos")
}

model CarritoItem {
  id         Int      @id @default(autoincrement())
  carritoId  Int
  productoId Int
  varianteId Int?
  cantidad   Int      @default(1)
  // Snapshot del precio al momento de agregar
  // (puede cambiar antes de confirmar)
  precioUnit Decimal  @db.Decimal(12, 2)
  creadoEn   DateTime @default(now())

  carrito    Carrito          @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  producto   Producto         @relation(fields: [productoId], references: [id], onDelete: Cascade)
  variante   ProductoVariante? @relation(fields: [varianteId], references: [id], onDelete: SetNull)

  @@index([carritoId, productoId]) // no duplicar el mismo producto+variante
  @@index([productoId])
  @@map("carrito_items")
}

// ─────────────────────────────────────────────
// PEDIDO
// ─────────────────────────────────────────────

enum EstadoPedido {
  PENDIENTE    // recién creado, esperando confirmación del owner
  CONFIRMADO   // owner lo aceptó
  EN_CAMINO    // salió para entrega
  ENTREGADO    // entregado al cliente
  CANCELADO    // cancelado por cualquiera de las partes
}

model Pedido {
  id               Int          @id @default(autoincrement())
  tiendaId         Int
  clienteId        Int?         // null = invitado
  // ── Datos del comprador (snapshot) ──────────
  // Se guardan aunque el cliente borre su cuenta
  compradorNombre  String       @db.VarChar(150)
  compradorEmail   String       @db.VarChar(180)
  compradorTel     String       @db.VarChar(30)
  // ── Entrega ─────────────────────────────────
  metodoEntregaId  Int
  // Snapshot de la dirección al momento del pedido
  direccionCalle   String       @db.VarChar(150)
  direccionNumero  String?      @db.VarChar(20)
  direccionPiso    String?      @db.VarChar(20)
  direccionCiudad  String       @db.VarChar(80)
  direccionProv    String       @db.VarChar(80)
  direccionCP      String?      @db.VarChar(20)
  direccionNotas   String?      @db.VarChar(300)
  // ── Pago ────────────────────────────────────
  metodoPagoId     Int
  // ── Totales ─────────────────────────────────
  subtotal         Decimal      @db.Decimal(12, 2)
  total            Decimal      @db.Decimal(12, 2)
  moneda           String       @default("ARS") @db.Char(3)
  // ── Estado ──────────────────────────────────
  estado           EstadoPedido @default(PENDIENTE)
  notasCliente     String?      @db.Text
  notasOwner       String?      @db.Text  // notas internas del dueño
  creadoEn         DateTime     @default(now())
  actualizadoEn    DateTime     @updatedAt

  tienda         Tienda        @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  cliente        ClienteTienda? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  metodoEntrega  MetodoEntrega @relation(fields: [metodoEntregaId], references: [id])
  metodoPago     MetodoPago    @relation(fields: [metodoPagoId], references: [id])
  items          PedidoItem[]

  @@index([tiendaId])
  @@index([clienteId])
  @@index([estado])
  @@map("pedidos")
}

model PedidoItem {
  id           Int      @id @default(autoincrement())
  pedidoId     Int
  productoId   Int
  varianteId   Int?
  // Snapshots — el producto puede cambiar después
  nombreProd   String   @db.VarChar(200)
  nombreVar    String?  @db.VarChar(150)
  imagenUrl    String?  @db.VarChar(500)
  cantidad     Int
  precioUnit   Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2) // precioUnit * cantidad

  pedido       Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto     Producto         @relation(fields: [productoId], references: [id], onDelete: Restrict)
  variante     ProductoVariante? @relation(fields: [varianteId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@map("pedido_items")
}