generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                    Int           @id @default(autoincrement())
  nombre                String        @db.VarChar(100)
  apellido              String        @db.VarChar(100)
  email                 String        @unique @db.VarChar(180)
  passwordHash          String        @db.VarChar(255)
  rol                   RolUsuario    @default(CLIENT)
  telefono              String?       @db.VarChar(30)
  avatarUrl             String?       @db.VarChar(500)
  emailVerificado       Boolean       @default(false)
  tokenVerificacion     String?       @db.VarChar(100)
  tokenVencVerificacion DateTime?
  tokenResetPass        String?       @db.VarChar(100)
  tokenVencReset        DateTime?
  activo                Boolean       @default(false)
  creadoEn              DateTime      @default(now())
  actualizadoEn         DateTime      @updatedAt
  logBusquedas          LogBusqueda[]
  tienda                Tienda?

  @@map("usuarios")
}

model PlantillaTienda {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(80)
  descripcion   String?  @db.Text
  previewUrl    String?  @db.VarChar(500)
  defaultConfig Json?
  sortOrder     Int      @default(0)
  activo        Boolean  @default(true)
  tiendas       Tienda[]

  @@map("plantillas_tienda")
}

model Tienda {
  id                    Int                   @id @default(autoincrement())
  usuarioId             Int                   @unique
  plantillaId           Int?
  slug                  String                @unique @db.VarChar(120)
  // Dominio propio del comprador (ej: "www.mitienda.com"). Opcional y único.
  // Solo se sirve la tienda por este dominio cuando dominioVerificado = true.
  dominioPersonalizado  String?               @unique @db.VarChar(255)
  dominioVerificado     Boolean               @default(false)
  // Código único que el dueño debe publicar como registro TXT en su DNS para probar la propiedad.
  dominioTokenVerif     String?               @db.VarChar(100)
  nombre                String                @db.VarChar(150)
  titulo                String?               @db.VarChar(200)
  descripcion           String?               @db.Text
  // Rubro del negocio elegido al crear la tienda (ej: "indumentaria"). Filtra qué
  // categorías ve/usa la tienda. Nullable para tiendas creadas antes de esta feature.
  rubro                 String?               @db.VarChar(60)
  logoUrl               String?               @db.VarChar(500)
  bannerUrl             String?               @db.VarChar(500)
  whatsapp              String?               @db.VarChar(30)
  instagram             String?               @db.VarChar(100)
  facebook              String?               @db.VarChar(100)
  sitioWeb              String?               @db.VarChar(255)
  pais                  String?               @db.VarChar(80)
  provincia             String?               @db.VarChar(80)
  ciudad                String?               @db.VarChar(80)
  // Datos legales del vendedor (identificación del proveedor en e-commerce)
  razonSocial           String?               @db.VarChar(200)
  cuit                  String?               @db.VarChar(20)
  domicilioLegal        String?               @db.VarChar(300)
  // Configuración de email marketing (cada tienda usa su propio proveedor / credenciales).
  emailProveedor        String?               @db.VarChar(30) // "smtp" | "brevo" | ...
  emailRemitente        String?               @db.VarChar(180) // desde qué dirección se envía
  emailRemitenteNombre  String?               @db.VarChar(120) // nombre visible del remitente
  emailHost             String?               @db.VarChar(180) // host SMTP (ej: smtp.gmail.com)
  emailPort             Int? // puerto SMTP (ej: 587)
  emailUsuario          String?               @db.VarChar(180) // usuario SMTP
  emailCredencial       String?               @db.Text // credencial CIFRADA (nunca en texto plano)
  emailVerificadoConfig Boolean               @default(false) // si ya se validó que las credenciales funcionan
  activa                Boolean               @default(true)
  publica               Boolean               @default(true)
  vistas                Int                   @default(0)
  creadoEn              DateTime              @default(now())
  actualizadoEn         DateTime              @updatedAt
  carritos              Carrito[]
  carrusel              CarruselImagen[]
  categoriasDestacadas  CategoriaDestacada[]
  clientes              ClienteTienda[]
  metodosEntrega        MetodoEntregaTienda[]
  metodosPago           MetodoPagoTienda[]
  pedidos               Pedido[]
  popups                TiendaPopup[]
  productos             Producto[]
  resenas               ResenaTienda[]
  aboutUs               TiendaAboutUs?
  marqueeItems          TiendaMarqueeItem[]
  visitas_log           VisitaTienda[]
  cupones               Cupon[]
  promociones           Promocion[]
  campanas              Campana[]
  guiasTalles           GuiaTalles[]
  revocaciones          SolicitudRevocacion[]
  paginasLegales        PaginaLegal[]
  temaConfig            TiendaTemaConfig?
  plantilla             PlantillaTienda?      @relation(fields: [plantillaId], references: [id])
  usuario               Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([plantillaId])
  @@map("tiendas")
}

model VisitaTienda {
  id         Int      @id @default(autoincrement())
  tiendaId   Int
  productoId Int? // si la visita fue a un producto puntual
  sessionId  String?  @db.VarChar(100)
  creadoEn   DateTime @default(now())
  tienda     Tienda   @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@index([tiendaId, creadoEn])
  @@index([productoId])
  @@map("visitas_tienda")
}

model TiendaTemaConfig {
  tiendaId                     Int                    @id
  colorAcento                  String?                @db.Char(7)
  navbarStyle                  NavbarStyle            @default(TRANSPARENT)
  navbarVariante               NavbarVariante         @default(CLASICO)
  navbarColorTema              NavbarColorTema        @default(OSCURO)
  cardVariante                 CardVariante           @default(CLASICO)
  footerVariante               FooterVariante         @default(CENTRADO)
  botonForma                   BotonForma             @default(REDONDEADO)
  fuenteKit                    FuenteKit              @default(MODERNO)
  heroTitulo                   String?                @db.VarChar(200)
  heroSubtitulo                String?                @db.VarChar(300)
  heroCtaTexto                 String?                @db.VarChar(100)
  cardMostrarPrecio            Boolean                @default(true)
  cardMostrarBadge             Boolean                @default(true)
  seccionesVisibles            Json?
  // Filas por categoría en el home: array ordenado de IDs de categoría (número[]).
  homeCategoriaFilas           Json?
  tipoSeccionHero              TipoSeccionHero        @default(HERO_FIJO)
  intervaloCarrusel            Int                    @default(5000)
  bannerPromoActivo            Boolean                @default(false)
  bannerPromoTitulo            String?                @db.VarChar(200)
  bannerPromoSubtitulo         String?                @db.VarChar(300)
  bannerPromoImagenUrl         String?                @db.VarChar(500)
  bannerPromoLinkUrl           String?                @db.VarChar(500)
  bannerPromoCtaTexto          String?                @db.VarChar(100)
  categoriasDestacadasActivas  Boolean                @default(false)
  categoriasDestacadasPosicion PosicionCategoriasDest @default(ANTES)
  creadoEn                     DateTime               @default(now())
  actualizadoEn                DateTime               @updatedAt
  modoOscuro                   Boolean                @default(true)
  tienda                       Tienda                 @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@map("tienda_tema_config")
}

model TiendaAboutUs {
  tiendaId      Int      @id
  titulo        String?  @db.VarChar(200)
  descripcion   String?  @db.Text
  imagenUrl     String?  @db.VarChar(500)
  direccion     String?  @db.VarChar(300)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  tienda        Tienda   @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@map("tienda_about_us")
}

model TiendaMarqueeItem {
  id       Int    @id @default(autoincrement())
  tiendaId Int
  texto    String @db.VarChar(100)
  orden    Int    @default(0)
  tienda   Tienda @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@index([tiendaId])
  @@map("tienda_marquee_items")
}

model MetodoPago {
  id          Int                @id @default(autoincrement())
  nombre      String             @unique @db.VarChar(80)
  icono       String?            @db.VarChar(50)
  descripcion String?            @db.VarChar(255)
  activo      Boolean            @default(true)
  orden       Int                @default(0)
  tiendas     MetodoPagoTienda[]
  pedidos     Pedido[]

  @@map("metodos_pago")
}

model MetodoEntrega {
  id          Int                   @id @default(autoincrement())
  nombre      String                @unique @db.VarChar(80)
  icono       String?               @db.VarChar(50)
  descripcion String?               @db.VarChar(255)
  permiteZona Boolean               @default(false)
  activo      Boolean               @default(true)
  orden       Int                   @default(0)
  tiendas     MetodoEntregaTienda[]
  pedidos     Pedido[]

  @@map("metodos_entrega")
}

model MetodoPagoTienda {
  tiendaId     Int
  metodoPagoId Int
  detalle      String?    @db.VarChar(255)
  configExtra  Json? // Configuración específica por tipo: { mpAccessToken, mpPublicKey, cbu, alias, ... }
  metodoPago   MetodoPago @relation(fields: [metodoPagoId], references: [id])
  tienda       Tienda     @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@id([tiendaId, metodoPagoId])
  @@index([metodoPagoId])
  @@map("metodos_pago_tienda")
}

model MetodoEntregaTienda {
  tiendaId        Int
  metodoEntregaId Int
  zonaCobertura   String?       @db.VarChar(255)
  detalle         String?       @db.VarChar(255)
  costo           Decimal?      @db.Decimal(10, 2) // Precio del envío (null = gratis)
  costoGratis     Decimal?      @db.Decimal(10, 2) // Monto mínimo para envío gratis
  tiempoEstimado  String?       @db.VarChar(100) // Ej: "2-3 días hábiles"
  metodoEntrega   MetodoEntrega @relation(fields: [metodoEntregaId], references: [id])
  tienda          Tienda        @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@id([tiendaId, metodoEntregaId])
  @@index([metodoEntregaId])
  @@map("metodos_entrega_tienda")
}

model CarruselImagen {
  id         Int             @id @default(autoincrement())
  tiendaId   Int
  url        String          @db.VarChar(500)
  titulo     String?         @db.VarChar(200)
  subtitulo  String?         @db.VarChar(300)
  linkUrl    String?         @db.VarChar(500)
  orden      Int             @default(0)
  activa     Boolean         @default(true)
  tipo       TipoSeccionHero @default(CARRUSEL)
  etiqueta   String?         @db.VarChar(100)
  fechaDesde DateTime?
  fechaHasta DateTime?
  tienda     Tienda          @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@index([tiendaId])
  @@map("carrusel_imagenes")
}

model CategoriaDestacada {
  id        Int      @id @default(autoincrement())
  tiendaId  Int
  imagenUrl String   @db.VarChar(500)
  titulo    String   @db.VarChar(200)
  linkUrl   String   @db.VarChar(500)
  orden     Int      @default(0)
  activa    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  tienda    Tienda   @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@index([tiendaId])
  @@map("categorias_destacadas")
}

model Categoria {
  id        Int         @id @default(autoincrement())
  padreId   Int?
  nombre    String      @db.VarChar(100)
  slug      String      @unique @db.VarChar(120)
  iconoUrl  String?     @db.VarChar(500)
  // Rubro del negocio al que pertenece esta categoría (ej: "indumentaria").
  // Se setea solo en las categorías RAÍZ (padreId = null); los descendientes lo heredan
  // implícitamente por su raíz. Sirve para filtrar qué categorías ve cada tienda según su rubro.
  rubro     String?     @db.VarChar(60)
  activa    Boolean     @default(true)
  padre     Categoria?  @relation("CategoriaHijos", fields: [padreId], references: [id])
  hijos     Categoria[] @relation("CategoriaHijos")
  productos Producto[]

  @@index([padreId])
  @@index([rubro])
  @@map("categorias")
}

model Tag {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique @db.VarChar(80)
  productos Producto[] @relation("productototag")

  @@map("tags")
}

model Producto {
  id                 Int                 @id @default(autoincrement())
  tiendaId           Int
  categoriaId        Int?
  nombre             String              @db.VarChar(200)
  descripcion        String?             @db.Text
  precio             Decimal             @db.Decimal(12, 2)
  precioOferta       Decimal?            @db.Decimal(12, 2)
  precioAnterior     Decimal?            @db.Decimal(12, 2)
  moneda             String              @default("ARS") @db.Char(3)
  imagenPrincipalUrl String?             @db.VarChar(500)
  disponible         Boolean             @default(true)
  destacado          Boolean             @default(false)
  vistas             Int                 @default(0)
  stock              Int                 @default(0)
  creadoEn           DateTime            @default(now())
  actualizadoEn      DateTime            @updatedAt
  carritoItems       CarritoItem[]
  pedidoItems        PedidoItem[]
  imagenes           ProductoImagen[]
  variantes          ProductoVariante[]
  guiaTallesId       Int?
  categoria          Categoria?          @relation(fields: [categoriaId], references: [id])
  tienda             Tienda              @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  guiaTalles         GuiaTalles?         @relation(fields: [guiaTallesId], references: [id], onDelete: SetNull)
  resenas            ResenaProducto[]
  tags               Tag[]               @relation("productototag")
  promociones        PromocionProducto[]

  @@index([tiendaId])
  @@index([categoriaId])
  @@index([guiaTallesId])
  @@map("productos")
}

// Tabla de talles reusable a nivel tienda (ej: "Remeras", "Calzado").
// columnas: ["Talle", "Pecho", "Largo"] (encabezados)
// filas: [["S","48","68"], ["M","51","70"]] (cada fila alineada a columnas)
model GuiaTalles {
  id            Int        @id @default(autoincrement())
  tiendaId      Int
  nombre        String     @db.VarChar(120)
  columnas      Json
  filas         Json
  nota          String?    @db.VarChar(500)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  tienda        Tienda     @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  productos     Producto[]

  @@index([tiendaId])
  @@map("guias_talles")
}

model ProductoImagen {
  id         Int      @id @default(autoincrement())
  productoId Int
  url        String   @db.VarChar(500)
  orden      Int      @default(0)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@map("producto_imagenes")
}

model ProductoVariante {
  id           Int           @id @default(autoincrement())
  productoId   Int
  nombre       String        @db.VarChar(150)
  color        String?       @db.VarChar(80)
  talle        String?       @db.VarChar(80)
  sku          String?       @db.VarChar(100)
  precioExtra  Decimal       @default(0.00) @db.Decimal(10, 2)
  imagenUrl    String?       @db.VarChar(500)
  stock        Int           @default(0)
  disponible   Boolean       @default(true)
  carritoItems CarritoItem[]
  pedidoItems  PedidoItem[]
  producto     Producto      @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@map("producto_variantes")
}

model ResenaTienda {
  id           Int            @id @default(autoincrement())
  tiendaId     Int
  clienteId    Int?
  autorNombre  String?        @db.VarChar(100)
  calificacion Int
  comentario   String?        @db.Text
  aprobada     Boolean        @default(false)
  eliminada    Boolean        @default(false)
  respuesta    String?        @db.Text
  respuestaEn  DateTime?
  creadoEn     DateTime       @default(now())
  tienda       Tienda         @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  cliente      ClienteTienda? @relation(fields: [clienteId], references: [id])

  @@index([tiendaId])
  @@index([clienteId])
  @@map("resenas_tienda")
}

model ResenaProducto {
  id           Int            @id @default(autoincrement())
  productoId   Int
  clienteId    Int?
  autorNombre  String?        @db.VarChar(100)
  calificacion Int
  comentario   String?        @db.Text
  imagenUrl    String?        @db.VarChar(500)
  aprobada     Boolean        @default(false)
  eliminada    Boolean        @default(false)
  respuesta    String?        @db.Text
  respuestaEn  DateTime?
  creadoEn     DateTime       @default(now())
  producto     Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade)
  cliente      ClienteTienda? @relation(fields: [clienteId], references: [id])

  @@index([productoId])
  @@index([clienteId])
  @@map("resenas_producto")
}

model LogBusqueda {
  id         BigInt   @id @default(autoincrement())
  termino    String   @db.VarChar(255)
  tiendaId   Int?
  usuarioId  Int?
  resultados Int?     @default(0)
  creadoEn   DateTime @default(now())
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([tiendaId])
  @@map("log_busquedas")
}

model ClienteTienda {
  id              Int                @id @default(autoincrement())
  tiendaId        Int
  email           String             @db.VarChar(180)
  nombre          String             @db.VarChar(100)
  apellido        String             @db.VarChar(100)
  telefono        String             @db.VarChar(30)
  passwordHash    String             @db.VarChar(255)
  emailVerificado Boolean            @default(false)
  tokenVerif      String?            @db.VarChar(100)
  tokenVerifVenc  DateTime?
  tokenResetPass  String?            @db.VarChar(100)
  tokenVencReset  DateTime?
  activo          Boolean            @default(true)
  creadoEn        DateTime           @default(now())
  actualizadoEn   DateTime           @updatedAt
  carritos        Carrito[]
  tienda          Tienda             @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  direcciones     DireccionCliente[]
  pedidos         Pedido[]
  resenasProducto ResenaProducto[]
  resenasTienda   ResenaTienda[]

  @@unique([tiendaId, email])
  @@index([tiendaId])
  @@map("clientes_tienda")
}

model DireccionCliente {
  id           Int           @id @default(autoincrement())
  clienteId    Int
  alias        String?       @db.VarChar(50)
  calle        String        @db.VarChar(150)
  numero       String?       @db.VarChar(20)
  piso         String?       @db.VarChar(20)
  ciudad       String        @db.VarChar(80)
  provincia    String        @db.VarChar(80)
  codigoPostal String?       @db.VarChar(20)
  indicaciones String?       @db.VarChar(300)
  esPrincipal  Boolean       @default(false)
  creadoEn     DateTime      @default(now())
  cliente      ClienteTienda @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("direcciones_cliente")
}

model Carrito {
  id            Int            @id @default(autoincrement())
  tiendaId      Int
  clienteId     Int?
  sessionId     String         @db.VarChar(100)
  expiresAt     DateTime
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt
  items         CarritoItem[]
  cliente       ClienteTienda? @relation(fields: [clienteId], references: [id])
  tienda        Tienda         @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@unique([tiendaId, sessionId])
  @@index([clienteId])
  @@map("carritos")
}

model CarritoItem {
  id         Int               @id @default(autoincrement())
  carritoId  Int
  productoId Int
  varianteId Int?
  cantidad   Int               @default(1)
  precioUnit Decimal           @db.Decimal(12, 2)
  creadoEn   DateTime          @default(now())
  carrito    Carrito           @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  producto   Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  variante   ProductoVariante? @relation(fields: [varianteId], references: [id])

  @@index([carritoId, productoId])
  @@index([productoId])
  @@index([varianteId], map: "carrito_items_varianteId_fkey")
  @@map("carrito_items")
}

model Pedido {
  id              Int                   @id @default(autoincrement())
  tiendaId        Int
  clienteId       Int?
  compradorNombre String                @db.VarChar(150)
  compradorEmail  String                @db.VarChar(180)
  compradorTel    String                @db.VarChar(30)
  metodoEntregaId Int
  direccionCalle  String                @db.VarChar(150)
  direccionNumero String?               @db.VarChar(20)
  direccionPiso   String?               @db.VarChar(20)
  direccionCiudad String                @db.VarChar(80)
  direccionProv   String                @db.VarChar(80)
  direccionCP     String?               @db.VarChar(20)
  direccionNotas  String?               @db.VarChar(300)
  metodoPagoId    Int
  subtotal        Decimal               @db.Decimal(12, 2)
  total           Decimal               @db.Decimal(12, 2)
  moneda          String                @default("ARS") @db.Char(3)
  estado          EstadoPedido          @default(PENDIENTE)
  estadoPago      EstadoPago            @default(PENDIENTE)
  mpPreferenciaId String?               @db.VarChar(255)
  mpPaymentId     String?               @db.VarChar(255)
  notasCliente    String?               @db.Text
  notasOwner      String?               @db.Text
  costoEnvio      Decimal               @default(0.00) @db.Decimal(12, 2)
  cuponId         Int?
  cuponCodigo     String?               @db.VarChar(50)
  descuento       Decimal               @default(0.00) @db.Decimal(12, 2)
  nroSeguimiento  String?               @db.VarChar(100)
  urlSeguimiento  String?               @db.VarChar(500)
  creadoEn        DateTime              @default(now())
  actualizadoEn   DateTime              @updatedAt
  items           PedidoItem[]
  logs            LogPedido[]
  revocaciones    SolicitudRevocacion[]
  cliente         ClienteTienda?        @relation(fields: [clienteId], references: [id])
  metodoEntrega   MetodoEntrega         @relation(fields: [metodoEntregaId], references: [id])
  metodoPago      MetodoPago            @relation(fields: [metodoPagoId], references: [id])
  tienda          Tienda                @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  cupon           Cupon?                @relation(fields: [cuponId], references: [id])

  @@index([tiendaId])
  @@index([clienteId])
  @@index([estado])
  @@index([metodoEntregaId], map: "pedidos_metodoEntregaId_fkey")
  @@index([metodoPagoId], map: "pedidos_metodoPagoId_fkey")
  @@index([cuponId], map: "pedidos_cuponId_fkey")
  @@map("pedidos")
}

enum TipoDescuento {
  PORCENTAJE
  MONTO_FIJO
}

model Cupon {
  id            Int           @id @default(autoincrement())
  tiendaId      Int
  codigo        String        @db.VarChar(50)
  tipoDescuento TipoDescuento @default(PORCENTAJE)
  valor         Decimal       @db.Decimal(12, 2) // % (0-100) o monto fijo según tipo
  minCompra     Decimal?      @db.Decimal(12, 2) // monto mínimo de compra para aplicar
  validoDesde   DateTime?
  validoHasta   DateTime?
  usoMaximo     Int? // null = ilimitado
  usoActual     Int           @default(0)
  activo        Boolean       @default(true)
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  tienda        Tienda        @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  pedidos       Pedido[]

  @@unique([tiendaId, codigo])
  @@index([tiendaId])
  @@map("cupones")
}

// Promoción/colección de ofertas que agrupa productos y les aplica un descuento.
// A diferencia del Cupon (descuento a nivel carrito por código), la promoción
// afecta directamente el precio de los productos asociados mientras está vigente,
// y es navegable: si está activa aparece como link en el navbar (por su slug/nombre).
// El descuento puede ser GLOBAL (tipoDescuento/valor en la promo) y/o POR PRODUCTO
// (en PromocionProducto). Regla: si el producto tiene el suyo, gana sobre el global.
// La promo vigente PISA el precioOferta manual del producto.
model Promocion {
  id              Int                 @id @default(autoincrement())
  tiendaId        Int
  nombre          String              @db.VarChar(150)
  slug            String              @db.VarChar(160) // para el link público /ofertas/:slug
  // Descuento global opcional: si está, se aplica a los productos que no tengan uno propio.
  tipoDescuento   TipoDescuento?
  valor           Decimal?            @db.Decimal(12, 2) // % (0-100) o monto fijo según tipo
  validoDesde     DateTime?
  validoHasta     DateTime?
  activa          Boolean             @default(true)
  bannerTitulo    String?             @db.VarChar(200)
  bannerImagenUrl String?             @db.VarChar(500)
  creadoEn        DateTime            @default(now())
  actualizadoEn   DateTime            @updatedAt
  tienda          Tienda              @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  productos       PromocionProducto[]

  @@unique([tiendaId, slug])
  @@index([tiendaId])
  @@map("promociones")
}

model PromocionProducto {
  promocionId   Int
  productoId    Int
  // Descuento propio del producto dentro de esta promo (opcional).
  // Si está seteado, GANA sobre el descuento global de la promo.
  tipoDescuento TipoDescuento?
  valor         Decimal?       @db.Decimal(12, 2)
  promocion     Promocion      @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  producto      Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([promocionId, productoId])
  @@index([productoId])
  @@map("promocion_productos")
}

// Solicitud de revocación de compra (Botón de arrepentimiento — Res. 424/2020, art. 34 LDC).
// Se puede crear sin registro previo. Al crearse genera un código de constancia inmediato.
model SolicitudRevocacion {
  id             Int              @id @default(autoincrement())
  tiendaId       Int
  codigo         String           @unique @db.VarChar(20) // constancia, ej: ARR-3F7K9Q
  pedidoId       Int? // opcional: puede no recordar el nº
  nroPedidoTexto String?          @db.VarChar(50) // nº que el cliente escribió a mano
  nombre         String           @db.VarChar(150)
  email          String           @db.VarChar(180)
  telefono       String?          @db.VarChar(30)
  motivo         String?          @db.Text
  estado         EstadoRevocacion @default(PENDIENTE)
  respuestaOwner String?          @db.Text
  creadoEn       DateTime         @default(now())
  actualizadoEn  DateTime         @updatedAt
  tienda         Tienda           @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  pedido         Pedido?          @relation(fields: [pedidoId], references: [id])

  @@index([tiendaId])
  @@index([pedidoId], map: "solicitudes_revocacion_pedidoId_fkey")
  @@map("solicitudes_revocacion")
}

enum EstadoRevocacion {
  PENDIENTE
  EN_PROCESO
  RESUELTA
  RECHAZADA
}

// Páginas legales editables por tienda (T&C, privacidad, cambios y devoluciones).
// Una fila por (tienda, tipo). El contenido es texto plano con saltos de línea.
model PaginaLegal {
  id            Int             @id @default(autoincrement())
  tiendaId      Int
  tipo          TipoPaginaLegal
  titulo        String          @db.VarChar(150)
  contenido     String          @db.LongText
  activa        Boolean         @default(true)
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  tienda        Tienda          @relation(fields: [tiendaId], references: [id], onDelete: Cascade)

  @@unique([tiendaId, tipo])
  @@index([tiendaId])
  @@map("paginas_legales")
}

enum TipoPaginaLegal {
  TERMINOS
  PRIVACIDAD
  CAMBIOS
}

model PedidoItem {
